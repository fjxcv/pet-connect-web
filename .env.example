# 复制为 backend/.env 使用（本地开发）

SECRET_KEY=请换成随机长字符串
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 设为 true 时使用 SQLite，无需 MySQL
USE_SQLITE=true

# MySQL（USE_SQLITE 未设置或为 false 时生效）
DB_NAME=pet_rescue
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# 前端：复制到 frontend/.env.local
# REACT_APP_API_BASE_URL=http://localhost:8000/api

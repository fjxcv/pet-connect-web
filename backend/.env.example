# Django Settings
SECRET_KEY=your-production-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database (set USE_SQLITE=true for local dev without MySQL)
USE_SQLITE=true
DB_NAME=pet_rescue
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Email (set EMAIL_SMTP_ENABLED=true to send real mail via QQ SMTP)
EMAIL_SMTP_ENABLED=false
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USE_SSL=false
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@petrescue.local
PASSWORD_RESET_CODE_RECIPIENT=1714929806@qq.com

# LLM (OpenAI-compatible: iFlytek MaaS / OpenAI / DeepSeek)
# iFlytek: APIKey as apikey:secret from console; model id from service card or GET {base}/models
LLM_API_BASE=https://maas-api.cn-huabei-1.xf-yun.com/v2
LLM_API_KEY=
